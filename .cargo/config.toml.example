# Exemplo de configuração local do Cargo — copie para `.cargo/config.toml` e ajuste.
# O arquivo real NÃO é versionado: contém caminhos específicos da sua máquina.

[build]
# Recomendado no Windows com OneDrive/antivírus: aponte o target para fora de
# pastas sincronizadas (evita bloqueios do AppControl em binários recém-compilados).
# target-dir = "C:\\dev\\arreio-target"

# Necessário apenas se usar o toolchain GNU (stable-x86_64-pc-windows-gnu) com MSYS2:
# [target.x86_64-pc-windows-gnu]
# linker = "C:\\msys64\\ucrt64\\bin\\gcc.exe"
# ar     = "C:\\msys64\\ucrt64\\bin\\ar.exe"
